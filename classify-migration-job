#!/usr/bin/env bash
set -euo pipefail

VENTURE=""
STEP=""
DATE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --venture) VENTURE="$2"; shift 2 ;;
        --step)    STEP="$2";    shift 2 ;;
        --date)    DATE="$2";    shift 2 ;;
        *) echo "usage: classify-migration-job --venture <venture> --step <step> --date <date>" >&2; exit 1 ;;
    esac
done

if [[ -z "$VENTURE" || -z "$STEP" || -z "$DATE" ]]; then
    echo "usage: classify-migration-job --venture <venture> --step <step> --date <date>" >&2
    exit 1
fi

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

verbose_output=""
if ! verbose_output=$("$REPO_ROOT/run-migration-execute" \
    --venture "$VENTURE" \
    --step "$STEP" \
    --date "$DATE" \
    --mode classify-verbose); then
    echo "error: classification failed — planner output may not exist for $VENTURE step $STEP" >&2
    exit 1
fi

actual_class=$(echo "$verbose_output" | grep '^class:' | awk '{print $2}')
reason_code=$(echo "$verbose_output" | grep '^reason_code:' | awk '{print $2}')

if [[ "$actual_class" == "A" ]]; then
    execution_allowed="yes"
else
    execution_allowed="no"
fi

echo "venture:           $VENTURE"
echo "step:              $STEP"
echo "date:              $DATE"
echo "actual class:      $actual_class"
echo "reason code:       $reason_code"
echo "execution allowed: $execution_allowed"
