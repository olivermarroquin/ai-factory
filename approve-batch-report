#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
    echo "usage: approve-batch-report <batch-report.json>" >&2
    exit 1
fi

REPORT_FILE="$1"

if [[ ! -f "$REPORT_FILE" ]]; then
    echo "error: report file not found: $REPORT_FILE" >&2
    exit 1
fi

if ! jq empty "$REPORT_FILE" 2>/dev/null; then
    echo "error: report file contains invalid JSON: $REPORT_FILE" >&2
    exit 1
fi

already_approved=$(jq -r '.approved' "$REPORT_FILE")
if [[ "$already_approved" == "true" ]]; then
    echo "Report is already approved: $REPORT_FILE"
    exit 0
fi

approved_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

tmp_file="$(mktemp)"
jq --arg approved_at "$approved_at" \
    '.approved = true | .approved_at_utc = $approved_at' \
    "$REPORT_FILE" > "$tmp_file"
mv "$tmp_file" "$REPORT_FILE"

echo "Approved: $REPORT_FILE"
echo "approved_at_utc: $approved_at"

QUEUE_STATE_FILE="${REPORT_FILE/_batch-report.json/_queue-state.json}"

if [[ -f "$QUEUE_STATE_FILE" ]]; then
    tmp_file="$(mktemp)"
    jq --arg approved_at "$approved_at" \
        '.batch_status = "approved"
        | .updated_at_utc = $approved_at
        | (.jobs[] | select(.status == "preflight_ready") | .status) = "approved"
        | (.jobs[] | select(.status == "approved") | .approval_timestamp) = $approved_at' \
        "$QUEUE_STATE_FILE" > "$tmp_file"
    mv "$tmp_file" "$QUEUE_STATE_FILE"
    echo "queue state updated -> $QUEUE_STATE_FILE"
else
    echo "warning: no matching queue-state file found: $QUEUE_STATE_FILE" >&2
fi
